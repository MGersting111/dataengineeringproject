{
  "name": "orders-cdc",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.hostname": "postgres",
    "database.port": "5432",
    "database.user": "postgres",
    "database.password": "postgres",
    "database.dbname": "dataengineeringproject",
    "plugin.name": "pgoutput",
    "topic.prefix": "opsdb",
    "slot.name": "orders_cdc_slot",
    "publication.name": "orders_cdc_publication",
    "publication.autocreate.mode": "filtered",
    "table.include.list": "public.sales_order,public.purchase_order,public.production",
    "tombstones.on.delete": "false",
    "decimal.handling.mode": "string",
    "schema.history.internal.kafka.bootstrap.servers": "redpanda:9092",
    "schema.history.internal.kafka.topic": "schema-changes.opsdb"
  }
}